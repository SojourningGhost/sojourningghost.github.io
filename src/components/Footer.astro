---
// Site footer. `showReturn` controls whether the "← 目次" link is shown;
// it's hidden on the home page itself.
const { showReturn = true } = Astro.props as { showReturn?: boolean };
---
<footer class="site-footer">
  <div class="site-footer__inner">
    {showReturn
      ? <a href="/" rel="home">← 目次</a>
      : <span class="site-footer__meta">Sojourning&nbsp;Ghost</span>}
    <span class="site-footer__meta">translation &middot; editing &middot; notes</span>
  </div>
</footer>
